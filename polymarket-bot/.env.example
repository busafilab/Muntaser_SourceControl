# Polygon EOA that holds USDC.e and signs orders. NEVER commit the real .env.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Polymarket CLOB host. Use https://clob.polymarket.com for mainnet.
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137

# Signature type for the wallet:
#   0 = EOA, 1 = Polymarket Proxy (email login), 2 = Browser Wallet (MetaMask)
SIGNATURE_TYPE=0
# Required for SIGNATURE_TYPE 1 or 2; leave blank for EOA.
FUNDER_ADDRESS=

# Market to trade. Find token IDs at https://gamma-api.polymarket.com/markets
# YES_TOKEN_ID and NO_TOKEN_ID are the two condition outcome token IDs.
YES_TOKEN_ID=
NO_TOKEN_ID=

# --- Risk caps (hard limits, enforced before every order) ---
MAX_ORDER_USDC=25
MAX_OPEN_NOTIONAL_USDC=100
MAX_DAILY_LOSS_USDC=50
MIN_PRICE=0.05
MAX_PRICE=0.95

# --- Strategy knobs ---
SIGNAL_THRESHOLD=0.03
POLL_INTERVAL_SECONDS=15

# Set to 1 to actually place orders. 0 = log-only paper mode.
LIVE=0
